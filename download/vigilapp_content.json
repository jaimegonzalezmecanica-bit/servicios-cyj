    "external": {},
    "html": "<html lang=\"es\"><head>\n<!-- Google tag (gtag.js) -->\n<script async=\"\" src=\"https://www.googletagmanager.com/gtag/js?id=AW-18041225565\"></script>\n<script>\n  window.dataLayer = window.dataLayer || [];\n  function gtag(){dataLayer.push(arguments);}\n  gtag('js', new Date());\n\n  gtag('config', 'AW-18041225565');\n</script>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Botón de Pánico y Alarma Comunitaria | VigilApp</title>\n<meta name=\"description\" content=\"VigilApp: botón de pánico y alarma comunitaria desde tu celular. Protege a tu familia y comunidad con una app rápida y confiable.\">\n<meta name=\"keywords\" content=\"botón de pánico, alarma comunitaria, app seguridad vecinal, emergencia vecinal, VigilApp\">\n\n  \n  <meta name=\"description\" content=\"La app de seguridad comunitaria con botón SOS, reportes de incidentes y geolocalización para condominios. Disponible en Google Play y App Store.\">\n  \n  <!-- Bootstrap CSS -->\n  <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\n  <!-- Bootstrap Icons -->\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css\">\n  <!-- Google Fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\">\n  <!-- Custom CSS -->\n  <link rel=\"stylesheet\" href=\"styles.css\">\n<script type=\"text/javascript\" async=\"\" src=\"https://googleads.g.doubleclick.net/pagead/viewthroughconversion/18041225565/?random=1775859250520&amp;cv=11&amp;fst=1775859250520&amp;bg=ffffff&amp;guid=ON&amp;async=1&amp;en=gtag.config&amp;gtm=45be6481v9247406401za200zd9247406401xec&amp;gcd=13l3l3l3l1l1&amp;dma=0&amp;tag_exp=0~115938466~115938468&amp;u_w=800&amp;u_h=600&amp;url=https%3A%2F%2Fvigilapp.cl%2F&amp;rcb=10&amp;frm=0&amp;tiba=Bot%C3%B3n%20de%20P%C3%A1nico%20y%20Alarma%20Comunitaria%20%7C%20VigilApp&amp;hn=www.googleadservices.com&amp;npa=0&amp;pscdl=noapi&amp;auid=412710262.1775859251&amp;uaa=&amp;uab=&amp;uafvl=&amp;uamb=0&amp;uam=&amp;uap=&amp;uapv=&amp;uaw=0&amp;data=event%3Dgtag.config&amp;rfmt=3&amp;fmt=4\"></script></head>\n<body>\n  <!-- Navigation -->\n  <nav class=\"navbar navbar-expand-lg navbar-dark fixed-top\">\n    <div class=\"container\">\n      <a class=\"navbar-brand d-flex align-items-center\" href=\"#\">\n        <img src=\"vigilapp-logo-large.png\" alt=\"VigilApp\" height=\"40\" class=\"me-2\">\n        <span class=\"fw-bold\">VigilApp</span>\n      </a>\n      <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#navbarNav\">\n        <span class=\"navbar-toggler-icon\"></span>\n      </button>\n      <div class=\"collapse navbar-collapse\" id=\"navbarNav\">\n        <ul class=\"navbar-nav ms-auto\">\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"#quienes-somos\">Quiénes Somos</a>\n          </li>\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"#funcionalidades\">Funcionalidades</a>\n          </li>\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"#galeria\">Galería</a>\n          </li>\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"#testimonios\">Testimonios</a>\n          </li>\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"#demo\">Demo</a>\n          </li>\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"#precios\">Precios</a>\n          </li>\n          <li class=\"nav-item\">\n              <a class=\"nav-link\" href=\"#soporte\">Soporte</a>\n          </li>\n          <li class=\"nav-item\">\n            <a class=\"nav-link\" href=\"#contacto\">Contacto</a>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </nav>\n\n  <!-- Hero Section -->\n  <header class=\"hero\">\n    <div class=\"hero-overlay\"></div>\n    <div class=\"container\">\n      <div class=\"row align-items-center min-vh-100\">\n        <div class=\"col-lg-6\">\n          <div class=\"hero-content\">\n            <h1 class=\"display-4 fw-bold mb-4\">Seguridad inteligente para tu comunidad</h1>\n            <p class=\"lead mb-4\">Con VigilApp, tu condominio cuenta con botón SOS, reportes vecinales y geolocalización en tiempo real.</p>\n            <a href=\"#demo\" class=\"btn btn-primary btn-lg px-5 py-3\">\n              <i class=\"bi bi-calendar-check me-2\"></i>\n              Agendar una Demo\n            </a>\n          </div>\n        </div>\n        <div class=\"col-lg-6\">\n          <div class=\"hero-image text-center\">\n            <img src=\"app-screenshot.jpg\" alt=\"VigilApp Mobile\" class=\"img-fluid rounded-4 shadow-lg\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <!-- Quiénes Somos Section -->\n  <section id=\"quienes-somos\" class=\"about py-5\">\n    <div class=\"container\">\n      <div class=\"row align-items-center\">\n        <div class=\"col-lg-6\">\n          <div class=\"about-content\">\n            <h2 class=\"display-5 fw-bold mb-4\">Quiénes Somos</h2>\n            <p class=\"lead mb-4\">Somos un equipo de expertos en tecnología y seguridad comprometidos con crear soluciones innovadoras para comunidades residenciales.</p>\n            <p class=\"mb-4\">VigilApp nació de la necesidad de brindar herramientas de seguridad accesibles y efectivas que fortalezcan los lazos comunitarios y mejoren la calidad de vida de los residentes.</p>\n            <div class=\"about-stats\">\n              <div class=\"row g-4\">\n                <div class=\"col-6\">\n                  <div class=\"stat-item text-center\">\n                    <h3 class=\"h2 fw-bold text-primary-custom\">500+</h3>\n                    <p class=\"text-muted\">Condominios Conectados</p>\n                  </div>\n                </div>\n                <div class=\"col-6\">\n                  <div class=\"stat-item text-center\">\n                    <h3 class=\"h2 fw-bold text-primary-custom\">10K+</h3>\n                    <p class=\"text-muted\">Usuarios Activos</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-lg-6\">\n          <div class=\"about-image text-center\">\n            <img src=\"feature-community.png\" alt=\"Comunidad VigilApp\" class=\"img-fluid rounded-4 shadow-lg\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Features Section -->\n  <section id=\"funcionalidades\" class=\"features py-5\">\n    <div class=\"container\">\n      <div class=\"row\">\n        <div class=\"col-lg-8 mx-auto text-center mb-5\">\n          <h2 class=\"display-5 fw-bold mb-3\">¿Qué ofrece VigilApp?</h2>\n          <p class=\"lead text-muted\">Descubre todas las funcionalidades que hacen de VigilApp la mejor solución de seguridad comunitaria</p>\n        </div>\n      </div>\n      <div class=\"row g-4\">\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"feature-card h-100\">\n            <div class=\"feature-icon\">\n              <i class=\"bi bi-exclamation-triangle-fill\"></i>\n            </div>\n            <h3 class=\"h5 fw-bold mb-3\">Botón SOS</h3>\n            <p class=\"text-muted\">Activa alertas en segundos para informar emergencias a tu comunidad o familia.</p>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"feature-card h-100\">\n            <div class=\"feature-icon\">\n              <i class=\"bi bi-geo-alt-fill\"></i>\n            </div>\n            <h3 class=\"h5 fw-bold mb-3\">Reportes Georreferenciados</h3>\n            <p class=\"text-muted\">Informa incidentes como personas sospechosas, ruidos molestos o acoso desde tu celular.</p>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"feature-card h-100\">\n            <div class=\"feature-icon\">\n              <i class=\"bi bi-map-fill\"></i>\n            </div>\n            <h3 class=\"h5 fw-bold mb-3\">Mapa de Incidentes</h3>\n            <p class=\"text-muted\">Visualiza en tiempo real los eventos reportados dentro del perímetro de tu condominio.</p>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"feature-card h-100\">\n            <div class=\"feature-icon\">\n              <i class=\"bi bi-phone-fill\"></i>\n            </div>\n            <h3 class=\"h5 fw-bold mb-3\">Fácil de Usar</h3>\n            <p class=\"text-muted\">Interfaz intuitiva pensada para todos los miembros de la comunidad, desde jóvenes hasta adultos mayores.</p>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"feature-card h-100\">\n            <div class=\"feature-icon\">\n              <i class=\"bi bi-building-fill\"></i>\n            </div>\n            <h3 class=\"h5 fw-bold mb-3\">Planes por Comunidad</h3>\n            <p class=\"text-muted\">Suscripción mensual accesible que se adapta al tamaño de tu condominio o edificio.</p>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"feature-card h-100\">\n            <div class=\"feature-icon\">\n              <i class=\"bi bi-shield-check-fill\"></i>\n            </div>\n            <h3 class=\"h5 fw-bold mb-3\">Seguridad Garantizada</h3>\n            <p class=\"text-muted\">Protección de datos y privacidad con los más altos estándares de seguridad digital.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Gallery Section -->\n  <section id=\"galeria\" class=\"gallery py-5\">\n    <div class=\"container\">\n      <div class=\"row\">\n        <div class=\"col-lg-8 mx-auto text-center mb-5\">\n          <h2 class=\"display-5 fw-bold mb-3\">Galería</h2>\n          <p class=\"lead text-muted\">Descubre cómo VigilApp transforma la seguridad en comunidades reales</p>\n        </div>\n      </div>\n      <div class=\"row g-4\">\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"gallery-item\">\n            <img src=\"gallery-woman-sos.png\" alt=\"Mujer usando botón SOS\" class=\"img-fluid rounded-4\">\n            <div class=\"gallery-overlay\">\n              <div class=\"gallery-content\">\n                <h5 class=\"fw-bold\">Botón SOS Inmediato</h5>\n                <p>Activación rápida en situaciones de emergencia</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"gallery-item\">\n            <img src=\"gallery-reports.png\" alt=\"Reportes de incidentes\" class=\"img-fluid rounded-4\">\n            <div class=\"gallery-overlay\">\n              <div class=\"gallery-content\">\n                <h5 class=\"fw-bold\">Reportes Inteligentes</h5>\n                <p>Informa incidentes de manera rápida y precisa</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"gallery-item\">\n            <img src=\"gallery-map.png\" alt=\"Mapa de incidentes\" class=\"img-fluid rounded-4\">\n            <div class=\"gallery-overlay\">\n              <div class=\"gallery-content\">\n                <h5 class=\"fw-bold\">Mapa Interactivo</h5>\n                <p>Visualiza incidentes en tiempo real</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"gallery-item\">\n            <img src=\"gallery-family.png\" alt=\"Familia usando VigilApp\" class=\"img-fluid rounded-4\">\n            <div class=\"gallery-overlay\">\n              <div class=\"gallery-content\">\n                <h5 class=\"fw-bold\">Seguridad Familiar</h5>\n                <p>Protección para toda la familia</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"gallery-item\">\n            <img src=\"feature-geolocation.png\" alt=\"Geolocalización\" class=\"img-fluid rounded-4\">\n            <div class=\"gallery-overlay\">\n              <div class=\"gallery-content\">\n                <h5 class=\"fw-bold\">Geolocalización Precisa</h5>\n                <p>Ubicación exacta de cada reporte</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-6 col-lg-4\">\n          <div class=\"gallery-item\">\n            <img src=\"feature-security.png\" alt=\"Seguridad comunitaria\" class=\"img-fluid rounded-4\">\n            <div class=\"gallery-overlay\">\n              <div class=\"gallery-content\">\n                <h5 class=\"fw-bold\">Tranquilidad Total</h5>\n                <p>Vive con la seguridad que mereces</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Testimonials Section -->\n  <section id=\"testimonios\" class=\"testimonials py-5\">\n    <div class=\"container\">\n      <div class=\"row\">\n        <div class=\"col-lg-8 mx-auto text-center mb-5\">\n          <h2 class=\"display-5 fw-bold mb-3\">Lo que dirán tus vecinos...</h2>\n          <p class=\"lead text-muted\">Experiencias reales de comunidades que ya confían en VigilApp</p>\n        </div>\n      </div>\n      <div class=\"row g-4\">\n        <div class=\"col-md-6\">\n          <div class=\"testimonial-card\">\n            <div class=\"testimonial-content\">\n              <i class=\"bi bi-quote testimonial-quote\"></i>\n              <p class=\"mb-4\">\"Desde que usamos VigilApp, todos nos sentimos más conectados y seguros. ¡Una gran inversión para nuestra comunidad!\"</p>\n              <div class=\"testimonial-author\">\n                <strong>Administrador, Condominio Alto Norte</strong>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-6\">\n          <div class=\"testimonial-card\">\n            <div class=\"testimonial-content\">\n              <i class=\"bi bi-quote testimonial-quote\"></i>\n              <p class=\"mb-4\">\"Informé un perro suelto cerca del parque y en minutos ya estaba resuelto. ¡Excelente herramienta vecinal!\"</p>\n              <div class=\"testimonial-author\">\n                <strong>Ana R., Vecina</strong>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Demo Section -->\n  <section id=\"demo\" class=\"demo py-5\">\n    <div class=\"container\">\n      <div class=\"row\">\n        <div class=\"col-lg-8 mx-auto\">\n          <div class=\"demo-card\">\n            <div class=\"text-center mb-5\">\n              <h2 class=\"display-5 fw-bold mb-3\">Solicita una demo gratuita</h2>\n              <p class=\"lead\">Completa el formulario y conoce cómo VigilApp puede transformar la seguridad de tu comunidad.</p>\n            </div>\n            <form class=\"demo-form\">\n              <div class=\"row g-3\">\n                <div class=\"col-md-6\">\n                  <div class=\"form-floating\">\n                    <input type=\"text\" class=\"form-control\" id=\"nombre\" name=\"nombre\" placeholder=\"Tu nombre\" required=\"\">\n                    <label for=\"nombre\">Tu nombre</label>\n                  </div>\n                </div>\n                <div class=\"col-md-6\">\n                  <div class=\"form-floating\">\n                    <input type=\"email\" class=\"form-control\" id=\"email\" name=\"email\" placeholder=\"Correo electrónico\" required=\"\">\n                    <label for=\"email\">Correo electrónico</label>\n                  </div>\n                </div>\n                <div class=\"col-12\">\n                  <div class=\"form-floating\">\n                    <input type=\"text\" class=\"form-control\" id=\"condominio\" name=\"condominio\" placeholder=\"Nombre del condominio o edificio\">\n                    <label for=\"condominio\">Nombre del condominio o edificio</label>\n                  </div>\n                </div>\n                <div class=\"col-12\">\n                  <div class=\"form-floating\">\n                    <textarea class=\"form-control\" id=\"mensaje\" name=\"mensaje\" style=\"height: 120px\" placeholder=\"¿Qué te gustaría saber?\"></textarea>\n                    <label for=\"mensaje\">¿Qué te gustaría saber?</label>\n                  </div>\n                </div>\n                <div class=\"col-12\">\n                  <button type=\"submit\" class=\"btn btn-primary btn-lg w-100\">\n                    <i class=\"bi bi-send me-2\"></i>\n                    Enviar solicitud\n                  </button>\n                </div>\n              </div>\n            </form>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- FAQ Section -->\n  <section id=\"faq\" class=\"faq py-5\">\n    <div class=\"container\">\n      <div class=\"row\">\n        <div class=\"col-lg-8 mx-auto\">\n          <div class=\"text-center mb-5\">\n            <h2 class=\"display-5 fw-bold mb-3\">Preguntas Frecuentes</h2>\n            <p class=\"lead text-muted\">Resolvemos las dudas más comunes sobre VigilApp</p>\n          </div>\n          <div class=\"accordion\" id=\"faqAccordion\">\n            <div class=\"accordion-item\">\n              <h2 class=\"accordion-header\">\n                <button class=\"accordion-button\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#faq1\">\n                  ¿La app tiene costo?\n                </button>\n              </h2>\n              <div id=\"faq1\" class=\"accordion-collapse collapse show\" data-bs-parent=\"#faqAccordion\">\n                <div class=\"accordion-body\">\n                  VigilApp funciona bajo un modelo de suscripción mensual por comunidad. Consulta planes según tu tipo de condominio.\n                </div>\n              </div>\n            </div>\n            <div class=\"accordion-item\">\n              <h2 class=\"accordion-header\">\n                <button class=\"accordion-button collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#faq2\">\n                  ¿Quién puede usar la app?\n                </button>\n              </h2>\n              <div id=\"faq2\" class=\"accordion-collapse collapse\" data-bs-parent=\"#faqAccordion\">\n                <div class=\"accordion-body\">\n                  Todos los residentes del condominio, incluyendo familiares registrados, pueden utilizar la app sin restricciones.\n                </div>\n              </div>\n            </div>\n            <div class=\"accordion-item\">\n              <h2 class=\"accordion-header\">\n                <button class=\"accordion-button collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#faq3\">\n                  ¿Qué pasa si no tengo internet?\n                </button>\n              </h2>\n              <div id=\"faq3\" class=\"accordion-collapse collapse\" data-bs-parent=\"#faqAccordion\">\n                <div class=\"accordion-body\">\n                  Las alertas SOS están optimizadas para funcionar con baja conectividad. Estamos trabajando para integrar funcionalidades offline.\n                </div>\n              </div>\n            </div>\n            <div class=\"accordion-item\">\n              <h2 class=\"accordion-header\">\n                <button class=\"accordion-button collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#faq4\">\n                  ¿Está disponible en iPhone y Android?\n                </button>\n              </h2>\n              <div id=\"faq4\" class=\"accordion-collapse collapse\" data-bs-parent=\"#faqAccordion\">\n                <div class=\"accordion-body\">\n                  Sí, VigilApp está disponible en App Store y Google Play.\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n  \n  <!-- ========================================= -->\n<!-- SECCIÓN: PLANES Y PRECIOS - VigilApp -->\n<!-- ========================================= -->\n<section id=\"precios\" class=\"pricing py-5 bg-light\">\n  <div class=\"container\">\n    <!-- Título -->\n    <div class=\"row\">\n      <div class=\"col-lg-8 mx-auto text-center mb-5\">\n        <h2 class=\"display-5 fw-bold mb-3\">Planes y Precios</h2>\n        <p class=\"lead text-muted\">\n          Elige el plan que mejor se adapte al tamaño de tu comunidad.  \n          Todos los valores están expresados en <strong>UF por unidad / mes.\n          Precios por menos de $990 clp</strong>.\n          </p><p>(*) Se cobra un mínimo de 0,2 UF/mes por comunidad.</p>\n        <p></p>\n      </div>\n    </div>\n\n    <!-- Tabla de precios -->\n    <div class=\"table-responsive\">\n      <table class=\"table table-bordered table-striped align-middle text-center shadow-sm rounded-4\">\n        <thead class=\"table-primary\">\n          <tr>\n            <th scope=\"col\">Rango de Unidades</th>\n            <th scope=\"col\">Precio por Unidad (UF)</th>\n            <th scope=\"col\">Descripción</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td>1 – 10</td>\n            <td>0,025</td>\n            <td>Plan básico</td>\n          </tr>\n          <tr>\n            <td>11 – 25</td>\n            <td>0,024</td>\n            <td>Comunidades pequeñas</td>\n          </tr>\n          <tr>\n            <td>26 – 50</td>\n            <td>0,023</td>\n            <td>Comunidades medianas</td>\n          </tr>\n          <tr>\n            <td>51 – 100</td>\n            <td>0,022</td>\n            <td>Plan intermedio</td>\n          </tr>\n          <tr>\n            <td>101 – 200</td>\n            <td>0,021</td>\n            <td>Plan avanzado</td>\n          </tr>\n          <tr>\n            <td>201 – 500</td>\n            <td>0,020</td>\n            <td>Plan plus</td>\n          </tr>\n          <tr>\n            <td>501 – 1000</td>\n            <td>0,019</td>\n            <td>Grandes comunidades</td>\n          </tr>\n          <tr>\n            <td>1001 +</td>\n            <td>0,018</td>\n            <td>Plan especial</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n\n\n\n<!-- ========================================= -->\n<!-- FIN SECCIÓN PLANES Y PRECIOS -->\n<!-- ========================================= -->\n\n  \n<!-- Soporte Section -->\n<section id=\"soporte\" class=\"support py-5 bg-light\">\n  <div class=\"container\">\n    <div class=\"row\">\n      <div class=\"col-lg-8 mx-auto text-center mb-5\">\n        <h2 class=\"display-5 fw-bold mb-3\">Centro de Soporte</h2>\n        <p class=\"lead text-muted\">\n          Encuentra respuestas rápidas o ponte en contacto con nuestro equipo de asistencia.\n        </p>\n      </div>\n    </div>\n\n    <div class=\"row g-4\">\n      <!-- Tarjeta FAQ -->\n      <div class=\"col-md-4\">\n        <div class=\"support-card h-100 text-center p-4 border rounded-4 shadow-sm\">\n          <i class=\"bi bi-question-circle-fill display-4 text-primary mb-3\"></i>\n          <h3 class=\"h5 fw-bold mb-3\">Preguntas Frecuentes</h3>\n          <p class=\"text-muted\">Consulta las dudas más comunes sobre VigilApp.</p>\n          <a href=\"#faq\" class=\"btn btn-outline-primary btn-sm\">Ver FAQ</a>\n        </div>\n      </div>\n\n      <!-- Tarjeta Email -->\n      <div class=\"col-md-4\">\n        <div class=\"support-card h-100 text-center p-4 border rounded-4 shadow-sm\">\n          <i class=\"bi bi-envelope-fill display-4 text-primary mb-3\"></i>\n          <h3 class=\"h5 fw-bold mb-3\">Correo Electrónico</h3>\n          <p class=