// Prisma schema for Servicios Integrales CyJ - Persistent database
// All data is shared across all devices connected to the server

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/* ═══════════════════════════════════════════════════════════
   USERS
   ═══════════════════════════════════════════════════════════ */

model User {
  id            String   @id @default(cuid())
  name          String
  password      String   @default("cyj2025")
  role          String   @default("residente_guardia") // super_admin, admin, residente_guardia
  roleName      String   @default("Residente")
  conjunto      String   @default("general")
  unit          String   @default("-")
  phone         String   @default("")
  email         String   @unique
  online        Boolean  @default(false)
  memberSince   String   @default("2024")
  avatarInitial String   @default("U")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  alerts Alert[]
}

/* ═══════════════════════════════════════════════════════════
   ALERTS (includes SOS as category "sos")
   ═══════════════════════════════════════════════════════════ */

model Alert {
  id            String   @id @default(cuid())
  category      String   @default("otro")
  categoryIcon  String   @default("more-horizontal")
  title         String
  description   String   @default("")
  time          String
  fullTime      DateTime @default(now())
  location      String   @default("No especificada")
  status        String   @default("activa") // activa, en_revision, resuelta
  priority      String   @default("medium") // low, medium, high, critical
  comments      Int      @default(0)
  isAnonymous   Boolean  @default(false)
  lat           Float    @default(-33.3273)
  lng           Float    @default(-70.7628)
  photo         String?
  responseText  String?
  responsePhoto String?
  respondedAt   DateTime?
  userId        String?
  userName      String   @default("")
  userConjunto  String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

/* ═══════════════════════════════════════════════════════════
   CONJUNTOS (Torres/Barrios)
   ═══════════════════════════════════════════════════════════ */

model Conjunto {
  id           String  @id @default(cuid())
  extId        String  @unique @default("general") // e.g. "flamencos", "faisanes"
  name         String
  type         String  @default("casas") // casas, torres
  status       String  @default("operativo") // operativo, mantencion
  houses       Int?
  towersCount  Int?
  units        Int?
  floors       Int?
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/* ═══════════════════════════════════════════════════════════
   ANNOUNCEMENTS
   ═══════════════════════════════════════════════════════════ */

model Announcement {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  date        String
  author      String   @default("Administración")
  priority    String   @default("info") // info, warning, important
  createdAt   DateTime @default(now())
}

/* ═══════════════════════════════════════════════════════════
   GUARDS ON DUTY
   ═══════════════════════════════════════════════════════════ */

model Guard {
  id        String   @id @default(cuid())
  name      String
  shift     String
  startTime String
  endTime   String
  zone      String
  phone     String
  createdAt DateTime @default(now())
}
