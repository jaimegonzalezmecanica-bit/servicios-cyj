<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
        <string>$(CAPACITOR_DEBUG)</string>
    <key>CFBundleDevelopmentRegion</key>
        <string>es</string>
    <key>CFBundleDisplayName</key>
        <string>CyJ Seguridad</string>
    <key>CFBundleExecutable</key>
        <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
        <string>6.0</string>
    <key>CFBundleName</key>
        <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
        <string>APPL</string>
    <key>CFBundleShortVersionString</key>
        <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
        <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSRequiresIPhoneOS</key>
        <true/>

    <!-- Location Permissions - Required for GPS and SOS -->
    <key>NSLocationWhenInUseUsageDescription</key>
        <string>Servicios CyJ necesita tu ubicacion para mostrar alertas en el mapa, georeferenciar incidentes y activar el boton SOS con tu posicion exacta.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
        <string>Servicios CyJ necesita acceso a tu ubicacion en segundo plano para enviar alertas SOS precisas y rastrear incidentes de seguridad.</string>
    <key>NSLocationAlwaysUsageDescription</key>
        <string>Servicios CyJ usa tu ubicacion para mantener la seguridad del condominio, incluso cuando la app esta en segundo plano.</string>

    <!-- Allow background location updates for SOS monitoring -->
    <key>UIBackgroundModes</key>
        <array>
            <string>location</string>
        </array>

    <!-- Status Bar Configuration -->
    <key>UIViewControllerBasedStatusBarAppearance</key>
        <true/>
    <key>UIStatusBarStyle</key>
        <string>UIStatusBarStyleLightContent</string>

    <!-- Launch Screen -->
    <key>UILaunchStoryboardName</key>
        <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
        <string>Main</string>

    <!-- Device Capabilities -->
    <key>UIRequiredDeviceCapabilities</key>
        <array>
                <string>armv7</string>
                <string>location-services</string>
                <string>gps</string>
        </array>

    <!-- Supported Orientations -->
    <key>UISupportedInterfaceOrientations</key>
        <array>
                <string>UIInterfaceOrientationPortrait</string>
        </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
        <array>
                <string>UIInterfaceOrientationPortrait</string>
                <string>UIInterfaceOrientationPortraitUpsideDown</string>
                <string>UIInterfaceOrientationLandscapeLeft</string>
                <string>UIInterfaceOrientationLandscapeRight</string>
        </array>

    <!-- App Transport Security - Allow HTTP for development -->
    <key>NSAppTransportSecurity</key>
        <dict>
                <key>NSAllowsArbitraryLoads</key>
                <true/>
                <key>NSAllowsLocalNetworking</key>
                <true/>
        </dict>

    <!-- Prevent File Sharing through iTunes -->
    <key>UIFileSharingEnabled</key>
        <false/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
        <false/>

    <!-- Privacy - Photo Library (for attaching photos to alerts) -->
    <key>NSPhotoLibraryUsageDescription</key>
        <string>Servicios CyJ necesita acceso a tu galeria de fotos para adjuntar imagenes a los reportes de incidentes.</string>

    <!-- Privacy - Camera (for taking photos of incidents) -->
    <key>NSCameraUsageDescription</key>
        <string>Servicios CyJ necesita acceso a la camara para tomar fotos de incidentes y adjuntarlas a los reportes de seguridad.</string>

    <!-- Minimum iOS Version -->
    <key>MinimumOSVersion</key>
        <string>15.0</string>
</dict>
</plist>
